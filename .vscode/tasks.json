{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "vite:dev",
            "type": "shell",
            "command": "/opt/homebrew/bin/npm",
            "args": [
                "run",
                "dev"
            ],
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "owner": "vite",
                    "kind": "file",
                    "pattern": [
                        {
                            "regexp": "^(.*)$",
                            "file": 1,
                            "message": 1
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "VITE v",
                        "endsPattern": "ready in|Local:"
                    }
                }
            ]
        }
    ]
}
